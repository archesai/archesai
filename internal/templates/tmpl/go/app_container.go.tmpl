{{- /*
Template: app_container.go.tmpl
Generates: Container that creates Infrastructure with database repositories.
Expects:
- Entities: []*spec.Schema (entity schemas, for standalone apps)
- ProjectName: string
- InternalPackages: []InternalPackageWithEntities (for composition apps, has Repositories []string)
*/ -}}
{{template "header" .}}
package app

{{- if .InternalPackages }}
import (
{{- range .InternalPackages }}
	{{ .Alias }}app "{{ .ImportPath }}/app"
{{- end }}
	"{{ .ProjectName }}/database/postgres/repositories"
	sqliterepos "{{ .ProjectName }}/database/sqlite/repositories"
	"github.com/archesai/archesai/pkg/database"
	"github.com/archesai/archesai/pkg/events"
)

// NewInfrastructure creates Infrastructure by composing internal package infrastructure.
func NewInfrastructure(db *database.Database) *Infrastructure {
	publisher := events.NewNoOpPublisher()

	if db.IsSQLite() {
		sqlDB := db.SQLDB()
		return &Infrastructure{
{{- range .InternalPackages }}
			{{ pascalCase .Name }}: &{{ .Alias }}app.Infrastructure{
{{- range .Repositories }}
				{{ . }}Repo: sqliterepos.NewSQLite{{ . }}Repository(sqlDB),
{{- end }}
{{- if .NeedsPublisher }}
				Publisher: publisher,
{{- end }}
			},
{{- end }}
		}
	}

	pool := db.PgxPool()
	return &Infrastructure{
{{- range .InternalPackages }}
		{{ pascalCase .Name }}: &{{ .Alias }}app.Infrastructure{
{{- range .Repositories }}
			{{ . }}Repo: repositories.NewPostgres{{ . }}Repository(pool),
{{- end }}
{{- if .NeedsPublisher }}
			Publisher: publisher,
{{- end }}
		},
{{- end }}
	}
}
{{- else }}
import (
	"{{ .ProjectName }}/database/postgres/repositories"
	sqliterepos "{{ .ProjectName }}/database/sqlite/repositories"
	"github.com/archesai/archesai/pkg/database"
)

// NewInfrastructure creates Infrastructure with database repositories.
func NewInfrastructure(db *database.Database) *Infrastructure {
	if db.IsSQLite() {
		sqlDB := db.SQLDB()
		return &Infrastructure{
{{- range .Entities }}
			{{ .Name }}Repo: sqliterepos.NewSQLite{{ .Name }}Repository(sqlDB),
{{- end }}
		}
	}

	pool := db.PgxPool()
	return &Infrastructure{
{{- range .Entities }}
		{{ .Name }}Repo: repositories.NewPostgres{{ .Name }}Repository(pool),
{{- end }}
	}
}
{{- end }}
